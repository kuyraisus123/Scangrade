generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  firstName    String
  lastName     String
  email        String         @unique
  passwordHash String
  subjects     Subject[]
  templates    ExamTemplate[]
  scanSessions ScanSession[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("users")
}

model Subject {
  id        String         @id @default(cuid())
  code      String
  name      String
  year      String
  term      String
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  templates ExamTemplate[]
  students  Student[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("subjects")
}

model ExamTemplate {
  id               String        @id @default(cuid())
  name             String
  examType         String
  semester         String
  totalQuestions   Int
  year             String        @default("")
  totalScore       Float
  scorePerQuestion Float
  subjectId        String
  subject          Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sets             TemplateSet[]
  scanSessions     ScanSession[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@map("exam_templates")
}

model TemplateSet {
  id            String        @id @default(cuid())
  label         String
  order         Int
  templateId    String
  template      ExamTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  boundingBoxes BoundingBox[]
  scanSessions  ScanSession[]
  createdAt     DateTime      @default(now())

  @@unique([templateId, order])
  @@map("template_sets")
}

model BoundingBox {
  id             String      @id @default(cuid())
  questionNumber Int
  x              Float
  y              Float
  w              Float
  h              Float
  isAnswer       Boolean     @default(false)
  type           String      @default("answer")
  setId          String
  set            TemplateSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())

  @@map("bounding_boxes")
}

model ScanSession {
  id         String         @id @default(cuid())
  templateId String
  template   ExamTemplate   @relation(fields: [templateId], references: [id])
  setId      String
  set        TemplateSet    @relation(fields: [setId], references: [id])
  userId     String
  user       User           @relation(fields: [userId], references: [id])
  sheets     ScannedSheet[]
  scannedAt  DateTime       @default(now())

  @@map("scan_sessions")
}

model ScannedSheet {
  id                String      @id @default(cuid())
  imageUrl          String
  score             Float
  wrongCount        Int
  status            String      @default("done")
  sessionId         String
  session           ScanSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId         String?
  student           Student?    @relation(fields: [studentId], references: [id])
  detectedStudentId String?
  wrongItems        WrongItem[]
  createdAt         DateTime    @default(now())

  @@map("scanned_sheets")
}

model WrongItem {
  id             String       @id @default(cuid())
  questionNumber Int
  sheetId        String
  sheet          ScannedSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@map("wrong_items")
}

model Student {
  id        String         @id @default(cuid())
  studentId String
  name      String
  subjectId String
  subject   Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  sheets    ScannedSheet[]
  createdAt DateTime       @default(now())

  @@unique([studentId, subjectId])
  @@map("students")
}
